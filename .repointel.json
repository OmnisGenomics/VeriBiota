{
  "scan": {
    "exclude": [
      "**/*.db",
      "*.egg-info",
      ".cache",
      ".direnv",
      ".git",
      ".jj",
      ".next",
      ".pytest_cache",
      ".tmp",
      ".turbo",
      ".venv",
      ".venv-*",
      "__pycache__",
      "artifacts/",
      "build",
      "coverage",
      "dist",
      "dist/",
      "node_modules",
      "node_modules/",
      "target",
      "venv",
      "venv-*"
    ],
    "maxFileSizeBytes": 2097152,
    "denyExtensions": [
      ".7z",
      ".arrow",
      ".avif",
      ".bz2",
      ".class",
      ".db",
      ".dmg",
      ".dll",
      ".duckdb",
      ".dylib",
      ".exe",
      ".feather",
      ".gif",
      ".gz",
      ".ico",
      ".jar",
      ".jpeg",
      ".jpg",
      ".parquet",
      ".pdf",
      ".png",
      ".pyc",
      ".rar",
      ".sqlite",
      ".so",
      ".tar",
      ".tgz",
      ".war",
      ".wasm",
      ".webp",
      ".xz",
      ".zip"
    ],
    "budget": {
      "includedFilesWarning": 500,
      "includedFilesHigh": 2000,
      "includedBytesWarning": 20971520,
      "includedBytesHigh": 78643200,
      "riskyFilesWarning": 1,
      "riskyFilesHigh": 25
    }
  }
}
